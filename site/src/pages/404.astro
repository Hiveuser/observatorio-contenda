---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
---

<Base title="Pagina nao encontrada">
  <Header />
  <main style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; text-align: center; padding: 2rem;">
    <h1 style="font-size: 8rem; font-weight: 700; color: var(--accent-green); margin: 0; line-height: 1;">404</h1>
    <p style="font-size: 1.5rem; color: var(--text-secondary); margin: 1rem 0 2rem;">Pagina nao encontrada</p>
    <a href="/" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.5rem; background: var(--accent-green); color: var(--bg-primary); border-radius: 8px; text-decoration: none; font-weight: 600;">Voltar ao mapa</a>
  </main>
</Base>
