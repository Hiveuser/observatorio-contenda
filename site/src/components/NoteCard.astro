---
export interface Props {
  slug: string;
  titulo: string;
  tipo: string;
  status: string;
  tags?: string[];
  resumo?: string;
  criado_em?: string;
  lat?: number;
  lon?: number;
}

const { slug, titulo, tipo, status, tags, resumo, criado_em, lat, lon } = Astro.props;

const tipoLabels: Record<string, string> = {
  documento: 'Documento',
  entidade: 'Entidade',
  dossie: 'Dossie',
  fonte: 'Fonte',
  tema: 'Tema',
  timeline: 'Timeline',
  log: 'Log',
  contrato: 'Contrato',
  licitacao: 'Licitacao',
  evento: 'Evento',
  local: 'Local',
  especie: 'Especie',
  empresa: 'Empresa',
  pessoa_publica: 'Pessoa Publica',
  programa: 'Programa',
  indicador: 'Indicador',
};

const statusColors: Record<string, string> = {
  rascunho: '#78716c',
  em_revisao: '#d97706',
  publicavel: '#2563eb',
  publicado: '#16a34a',
  arquivado: '#a8a29e',
};
---

<a href={`/documentos/${slug}`} class="note-card card">
  <div class="note-card-header">
    <span class="badge tipo-badge">{tipoLabels[tipo] || tipo}</span>
    <span class="status-dot" style={`background: ${statusColors[status] || '#78716c'}`}></span>
    <span class="status-label">{status.replace('_', ' ')}</span>
  </div>
  <h3 class="note-card-title">{titulo}</h3>
  {resumo && <p class="note-card-resumo">{resumo}</p>}
  <div class="note-card-meta">
    {criado_em && <span class="meta-date">{criado_em}</span>}
    {lat && lon && <span class="meta-geo">Georreferenciado</span>}
  </div>
  {Array.isArray(tags) && tags.length > 0 && (
    <div class="note-card-tags">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  )}
</a>

<style>
  .note-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .note-card-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }
  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .status-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: capitalize;
  }
  .note-card-title {
    font-size: 1.1rem;
    margin-bottom: var(--space-sm);
    color: var(--color-primary-dark);
  }
  .note-card-resumo {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .note-card-meta {
    display: flex;
    gap: var(--space-md);
    font-size: 0.8rem;
    color: var(--color-text-light);
    margin-top: var(--space-sm);
  }
  .meta-geo {
    color: var(--color-primary);
    font-weight: 500;
  }
  .note-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-sm);
  }
  .tag {
    font-size: 0.7rem;
    padding: 0.1em 0.5em;
    background: #f0fdf4;
    color: var(--color-primary);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-accent-light);
  }
</style>