      <span class="w-8 h-px bg-floresta-600 inline-block"></span>
      Espécies Recomendadas
    </h2>

    <div data-animate class="overflow-x-auto">
      <table class="data-table w-full">
        <thead>
          <tr>
            <th class="text-left">#</th>
            <th class="text-left">Espécie</th>
            <th class="text-left">Nome Científico</th>
            <th class="text-left">Floração</th>
            <th class="text-center">Vias</th>
            <th class="text-center">Mudas</th>
            <th class="text-right">Custo</th>
