          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="font-body text-sm text-pergaminho-100">Ipê-amarelo-miúdo</td>
            <td class="font-data text-xs text-pergaminho-200/60">Medio (6-12m)</td>
            <td class="font-body text-xs text-pergaminho-200/70">IN 35/2019 MMA — Flora ameaçada; Lista Espécies Nativas PR</td>
            <td><a href="https://www.gov.br/mma" target="_blank" class="text-floresta-400 hover:text-terracota-400 text-xs">MMA ↗</a></td>
          </tr>
          <tr>
            <td class="font-body text-sm text-pergaminho-100">Erva-mate</td>
            <td class="font-data text-xs text-pergaminho-200/60">Medio (6-12m)</td>
            <td class="font-body text-xs text-pergaminho-200/70">IAT-PR — Instrução Normativa 01/2016; Resolução CONAMA 423/2010</td>
            <td><a href="https://www.iat.pr.gov.br" target="_blank" class="text-floresta-400 hover:text-terracota-400 text-xs">IAT-PR ↗</a></td>
