            <th class="text-left">Rua</th>
            <th class="text-left">Espécie</th>
            <th class="text-left">Porte</th>
            <th class="text-center">Extensão</th>
            <th class="text-center">Mudas</th>
            <th class="text-right">Custo</th>
          </tr>
        </thead>
        <tbody>
          {[...streets]
            .sort((a, b) => b.comprimento_m - a.comprimento_m)
            .slice(0, 10)
            .map((s, i) => (
              <tr>
                <td class="font-mono text-xs text-floresta-600">{String(i + 1).padStart(2, '0')}</td>
                <td class="font-body text-sm text-pergaminho-100">{s.nome}</td>
                <td class="font-body text-xs text-terracota-400">{s.species}</td>
