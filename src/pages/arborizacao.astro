---
import Base from '../layouts/Base.astro';
import fs from 'fs';
import path from 'path';

const base = import.meta.env.BASE_URL;
const geojsonPath = path.join(process.cwd(), 'public', 'data', 'vias-arborizadas.geojson');
const geojson = JSON.parse(fs.readFileSync(geojsonPath, 'utf-8'));

interface StreetSpecies {
  nome: string;
  species: string;
  nome_cientifico: string;
  porte: string;
  floracao: string;
  mudas: number;
  custo: number;
  tipo_via: string;
  comprimento_m: number;
}

const streets: StreetSpecies[] = geojson.features
  .filter((f: any) => f.properties.arborizacao && f.properties.nome)
  .map((f: any) => {
    const p = f.properties;
    const a = p.arborizacao;
    return {
      nome: p.nome || 'Sem nome',
      species: a?.especie_primaria || '—',
      nome_cientifico: a?.nome_cientifico || '—',
      porte: a?.porte || '—',
      floracao: a?.floracao || '—',
      mudas: a?.mudas_necessarias || 0,
      custo: a?.custo_estimado_mudas || 0,
      tipo_via: p.tipo || 'Não classificada',
      comprimento_m: p.comprimento_m || 0,
    };
  })
  .filter((s) => s.mudas > 0); // only streets with actual arborization data

const totalStreets = streets.length;
const totalMudas = streets.reduce((sum, s) => sum + s.mudas, 0);
const totalCusto = streets.reduce((sum, s) => sum + s.custo, 0);

// Species summary
const speciesMap = new Map<string, { count: number; mudas: number; custo: number; floracao: string }>();
streets.forEach((s) => {
  const existing = speciesMap.get(s.species) || { count: 0, mudas: 0, custo: 0, floracao: s.floracao };
  existing.count++;
  existing.mudas += s.mudas;
  existing.custo += s.custo;
  speciesMap.set(s.species, existing);
});

const speciesSummary = Array.from(speciesMap.entries())
  .sort((a, b) => b[1].mudas - a[1].mudas)
  .map(([name, data]) => ({ name, ...data }));

// Via type summary
const viaTypeMap = new Map<string, { count: number; length: number }>();
streets.forEach((s) => {
  const existing = viaTypeMap.get(s.tipo_via) || { count: 0, length: 0 };
  existing.count++;
  existing.length += s.comprimento_m;
  viaTypeMap.set(s.tipo_via, existing);
});

const viaTypeSummary = Array.from(viaTypeMap.entries())
  .sort((a, b) => b[1].length - a[1].length)
  .map(([name, data]) => ({ name, ...data }));
---

<Base
  title="Plano de Arborização Viária"
  description="Plano de arborização viária georreferenciado para Contenda/PR — 165 vias, 15.566 mudas nativas de Mata Atlântica."
