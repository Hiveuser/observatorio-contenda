<!-- Leaflet map script -->
<script define:vars={{ geojson }} is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof L === 'undefined') return;

    // Species color mapping
    const speciesNames = [...new Set(
      geojson.features
        .map(f => f.properties.arborizacao?.especie_primaria)
        .filter(Boolean)
    )];
    const colors = [
      '#4CAF50', '#FF9800', '#2196F3', '#E91E63', '#9C27B0',
      '#00BCD4', '#FF5722', '#795548', '#607D8B'
    ];
    const colorMap = {};
    speciesNames.forEach((name, i) => {
      colorMap[name] = colors[i % colors.length];
    });

    const styleFeature = (feature) => {
      const arb = feature.properties.arborizacao;
      const especie = arb?.especie_primaria;
      return {
        color: especie ? (colorMap[especie] || '#666') : '#444',
        weight: 3,
        opacity: 0.85,
      };
    };

    const onEachFeature = (feature, layer) => {
      const props = feature.properties;
      const arb = props.arborizacao;
      if (arb && props.nome) {
        const popup = `
          <strong>${props.nome}</strong><br/>
          <span style="color: ${colorMap[arb.especie_primaria] || '#888'}">●</span> ${arb.especie_primaria}<br/>
          <em style="font-size: 11px; color: #666;">${arb.nome_cientifico}</em><br/>
          Porte: ${arb.porte}<br/>
          Mudas: ${(arb.mudas_necessarias || 0).toLocaleString('pt-BR')} (esc. ${arb.espacamento_m}m)<br/>
          Extensão: ${(props.comprimento_m || 0).toFixed(0)}m · R$ ${(arb.custo_estimado_mudas || 0).toLocaleString('pt-BR')}
        `;
        layer.bindPopup(popup);
      }
    };

    // Filter out features without arborization data for the map
    const arborizedFeatures = geojson.features.filter(f => f.properties.arborizacao && f.properties.nome);
    const arborizedGeoJSON = { ...geojson, features: arborizedFeatures };

    const map = L.map('arborizacao-map', {
      renderer: L.canvas({ padding: 0.5 }),
    }).setView([-25.69, -49.51], 12);

    L.tileLayer('https://tiles.stadiamaps.com/tiles/alidade_smooth_dark/{z}/{x}/{y}{r}.png', {
      maxZoom: 19,
      attribution: '© Stadia Maps, © OpenStreetMap',
    }).addTo(map);

    // Schools and UBS layer
    const poiLayer = L.layerGroup([
      L.marker([-25.6755, -49.5333], {
        icon: L.divIcon({ className: '', html: '<span style="font-size:18px;filter:drop-shadow(0 1px 2px #0006)">🏫</span>', iconSize: [20, 20], iconAnchor: [10, 10] })
      }).bindPopup('<strong>Escolas/UBS</strong><br/>Áreas prioritárias para arborização'),
    ]);

    const streetsGeo = L.geoJSON(arborizedGeoJSON, {
      style: styleFeature,
      onEachFeature,
    });

    const baseLayers = {
      "Ruas Arborizadas": streetsGeo,
      "Escolas / UBS": poiLayer,
    };

    streetsGeo.addTo(map);
    L.control.layers(null, baseMarkers).addTo(map);

    // Legend
    const legend = L.control({ position: 'bottomright' });
    legend.onAdd = () => {
      const div = L.DomUtil.create('div', 'legend-panel');
      div.innerHTML = '<p style="font-family: monospace; font-size: 11px; color: #888; margin: 0 0 8px 0; text-transform: uppercase; letter-spacing: 1px;">Espécies</p>';
      Object.entries(colorMap).forEach(([name, color]) => {
        div.innerHTML += `<div style="display: flex; align-items: center; gap: 6px; margin-bottom: 4px;">
          <span style="width: 14px; height: 3px; background: ${color}; border-radius: 1px; flex-shrink: 0;"></span>
          <span style="font-family: sans-serif; font-size: 11px; color: #ccc;">${name}</span>
        </div>`;
      });
      div.style.background = 'rgba(10, 20, 15, 0.92)';
      div.style.padding = '10px 12px';
      div.style.borderRadius = '4px';
      div.style.border = '1px solid rgba(255,255,255,0.08)';
      div.style.maxWidth = '200px';
      div.style.pointerEvents = 'auto';
      return div;
    };
    legend.addTo(map);
  });

  // Load Leaflet JS dynamically
  (function () {
    if (typeof L !== 'undefined') return;
    const script = document.createElement('script');
    script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    script.crossOrigin = 'anonymous';
    document.head.appendChild(script);
  })();
</script>

<style>
  .legend-panel {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
  }
</style>
