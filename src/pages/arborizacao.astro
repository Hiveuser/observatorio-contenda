            <td class="text-center font-mono text-xs text-pergaminho-100">{totalStreets}</td>
            <td class="text-center font-mono text-xs text-pergaminho-100">{totalMudas.toLocaleString('pt-BR')}</td>
            <td class="text-right font-mono text-xs text-dado-verde">R$ {totalCusto.toLocaleString('pt-BR')}</td>
          </tr>
