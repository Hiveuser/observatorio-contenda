        ↓ Baixar GeoJSON
      </a>
      <a href="/data/vias-contenda.geojson" download
         class="font-mono text-xs bg-floresta-700/60 hover:bg-floresta-600/60 text-pergaminho-200 px-3 py-1 rounded-sm border border-floresta-700/40 transition-colors flex items-center gap-1">
        ↓ Baixar Vias Brutas
      </a>
    </div>
  </section>

  <div class="divider mx-6 md:mx-16"></div>

    <!-- DOWNLOADS -->
    <section class="py-6 px-6 max-w-7xl mx-auto">
      <div class="flex flex-wrap gap-3 items-center">
        <a href="/data/vias-arborizadas.geojson" download
