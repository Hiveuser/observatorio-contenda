      </div>
      <div data-animate class="indicador-card rounded-sm p-6 border-l-2 border-terracota-400/40">
        <p class="font-data text-xs tracking-widest uppercase text-terracota-400/70 mb-3">Área Urbana Estimada</p>
        <p class="font-display font-bold text-3xl text-terracota-400 mb-1">~1.8%</p>
        <p class="font-body text-xs text-pergaminho-200/60">~5.7 km²</p>
