          { label: 'Mudas previstas', value: totalMudas.toLocaleString('pt-BR'), sub: '9 espécies nativas', color: 'text-dado-verde' },
          { label: 'Custo plantio', value: `R$ ${(totalCusto / 1000).toFixed(0)}k`, sub: `R$ ${(totalCusto * 1.3 / 1000).toFixed(0)}k com manutenção`, color: 'text-terracota-400' },
          { label: 'Espécies', value: speciesSummary.length.toString(), sub: 'Mata Atlântica/PR', color: 'text-pergaminho-100' },
        ].map((item, i) => (
          <div data-animate class="indicador-card rounded-sm p-6" style={`animation-delay:${i * 0.08}s`}>
            <p class={`font-display font-bold text-3xl mb-2 ${item.color}`}>{item.value}</p>
