---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projetos = await getCollection('projetos', ({ data }) => data.public === true);
  return projetos.map((projeto) => ({
    params: { slug: projeto.slug },
    props: { projeto },
  }));
}

const { projeto } = Astro.props;
const { Content } = await projeto.render();

const statusLabel: Record<string, string> = {
  planejamento: 'Planejamento',
  ativo: 'Ativo',
  pausado: 'Pausado',
  concluido: 'Concluído',
};

const statusBadge: Record<string, string> = {
  planejamento: 'badge-medio',
  ativo: 'badge-ok',
  pausado: 'badge-alto',
  concluido: 'badge-critico',
};
---

<Base title={projeto.data.title} description={`Projeto ${projeto.data.title} — Observatório Contenda/PR`}>

  <article class="pt-32 pb-24 px-6 max-w-4xl mx-auto">

    <!-- Breadcrumb -->
    <nav class="mb-10 font-data text-xs text-floresta-600 flex items-center gap-2">
      <a href="/" class="hover:text-floresta-400 transition-colors">Início</a>
      <span>/</span>
      <a href="/projetos" class="hover:text-floresta-400 transition-colors">Projetos</a>
      <span>/</span>
      <span class="text-pergaminho-200/50">{projeto.data.title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-12">
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <span class={`inline-block ${statusBadge[projeto.data.status] ?? 'badge-medio'} font-mono text-[10px] px-2 py-1 rounded-sm`}>
          {statusLabel[projeto.data.status] ?? projeto.data.status}
        </span>
        {projeto.data.dominio && (
          <span class="font-mono text-xs text-floresta-500">{projeto.data.dominio}</span>
        )}
        {projeto.data.mvp_prazo && (
          <span class="font-mono text-xs text-pergaminho-200/40">MVP: {projeto.data.mvp_prazo}</span>
        )}
      </div>

      <h1 class="font-display font-black text-4xl md:text-5xl text-pergaminho-100 leading-tight mb-4">
        {projeto.data.title}
      </h1>

      {projeto.data.stack && (
        <p class="font-data text-sm text-floresta-500 tracking-wide">{projeto.data.stack}</p>
      )}

      <div class="divider mt-8"></div>
    </header>

    <!-- Content -->
    <div class="prose-observatorio">
      <Content />
    </div>

    <!-- Back link -->
    <div class="mt-16 pt-8 border-t border-floresta-800/40">
      <a href="/projetos"
         class="inline-flex items-center gap-2 font-data text-xs tracking-wider uppercase text-floresta-500 hover:text-floresta-400 transition-colors">
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
        </svg>
        Todos os projetos
      </a>
    </div>
  </article>

</Base>
