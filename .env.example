# ---------------------------------------------------------------------------
# Observatorio Georreferenciado de Contenda/PR -- Variaveis de Ambiente
# ---------------------------------------------------------------------------
# Copie para .env e ajuste os valores.

# Caminho do vault Obsidian (dentro do container: /app/vault)
VAULT_PATH=./vault

# Origens permitidas pelo CORS (separadas por virgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:4321

# User-Agent para requisicoes ao Nominatim (obrigatorio pela politica de uso)
NOMINATIM_USER_AGENT=observatorio-contenda/0.1.0

# Modo strict da validacao de frontmatter (true/false)
# Quando true, campos extras geram erro
STRICT_VALIDATION=false
